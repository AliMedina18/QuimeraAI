# ============================================================
# Quimera AI — .gitignore
# CRÍTICO: nunca subir credenciales o claves de API a GitHub
# ============================================================

# --- Variables de entorno y credenciales ---
.env
.env.local
.env.*.local
*.env
service-account*.json
gcp-credentials*.json
application_default_credentials.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# --- Pytest ---
.pytest_cache/
.coverage
htmlcov/
.tox/
*.prof

# --- Node.js (frontend Next.js) ---
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDEs y editores ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker ---
*.dockerignore

# --- Archivos temporales y de build ---
*.log
*.tmp
*.temp
/tmp/

# --- Cloud Build ---
.gcloudignore

# --- Archivos generados por Quimera (outputs del pipeline) ---
# No subir outputs generados durante desarrollo/testing
backend/outputs/
tests/generated_outputs/
tests/confusion_matrix_results.md
