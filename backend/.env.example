# backend/.env.example
# ====================
# Copia este archivo a backend/.env y rellena los valores reales.
# NUNCA subas backend/.env a GitHub. Está en .gitignore.
#
# En Cloud Run, estas variables se configuran en el servicio directamente
# o se leen desde Secret Manager (ver setup_gcp.sh).

# --- Gemini / Google AI ---
# Obtener desde: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# --- Unsplash API (imágenes dinámicas por brief) ---
# Registro gratis en: https://unsplash.com/developers → "New Application"
# Plan Demo: 50 req/hora. Sin clave → usa fotos curadas por industria como fallback.
UNSPLASH_ACCESS_KEY= 

# --- Google Cloud ---
GCP_PROJECT_ID=quimera-ai-prod
FIRESTORE_DATABASE=(default)

# --- Nombres de modelo (opcional, hay defaults) ---
# GEMINI_MODEL_PRO=gemini-2.5-pro
# GEMINI_MODEL_FLASH=gemini-2.5-flash

# --- Entorno ---
ENVIRONMENT=development

# --- CORS (en producción: URL exacta del frontend en Firebase Hosting) ---
# ALLOWED_ORIGINS=https://quimera-ai.web.app,https://quimera-ai.firebaseapp.com
ALLOWED_ORIGINS=*
